#!/bin/bash
# MT4 Indicator Pre-Commit Hook
# Validates staged .mq4 files for no-future-function compliance

STAGED_MQ4=$(git diff --cached --name-only --diff-filter=ACM | grep '\.mq4$')

if [ -z "$STAGED_MQ4" ]; then
    exit 0
fi

HAS_CRITICAL=0

# Files with known false positives in buffer count detection.
# These use loops or single-line multi-call patterns where grep counts lines not calls.
KNOWN_FALSE_POSITIVES=(
    "Trend/GuppyMMA_Safe.mq4"
    "Trend/RainbowMA_Safe.mq4"
    "Volume/VolumeFootprint_Safe.mq4"
    "Custom/ChanBi_Safe.mq4"
    "Custom/AbsorptionCandle_Safe.mq4"
    "Custom/BodyShadowRatio_Safe.mq4"
    "Custom/CCPV_Safe.mq4"
    "Custom/CandleBodyMomentum_Safe.mq4"
    "Custom/CandleCloseVsPrevRange_Safe.mq4"
    "Custom/CandleCompression_Safe.mq4"
    "Custom/CandleCountback_Safe.mq4"
    "Custom/CandleDisplacement_Safe.mq4"
    "Custom/CandleEquilibrium_Safe.mq4"
    "Custom/CandleImbalance_Safe.mq4"
    "Custom/CandleNoiseFilter_Safe.mq4"
    "Custom/CandleOverlap_Safe.mq4"
    "Custom/CandlePatternScanner_Safe.mq4"
    "Custom/CandlePhaseClassifier_Safe.mq4"
    "Custom/CandlePower_Safe.mq4"
    "Custom/CandleRangeProjection_Safe.mq4"
    "Custom/CandleRangeRank_Safe.mq4"
    "Custom/CandleRetracementDepth_Safe.mq4"
    "Custom/CandleTimeExhaustion_Safe.mq4"
    "Custom/CandleVelocity_Safe.mq4"
    "Custom/CandleVolumeProfile_Safe.mq4"
    "Custom/ChanZhongShu_Safe.mq4"
    "Custom/ColorChange_Safe.mq4"
    "Custom/ConsecutiveDirectionalClose_Safe.mq4"
    "Custom/ConsecutiveSmallBody_Safe.mq4"
    "Custom/DojiCluster_Safe.mq4"
    "Custom/EconomicSurprise_Safe.mq4"
    "Custom/EhlersFisher_Safe.mq4"
    "Custom/ElliottWave_Safe.mq4"
    "Custom/EngulfingCascade_Safe.mq4"
    "Custom/FakeBreakoutCandle_Safe.mq4"
    "Custom/FundingRate_Safe.mq4"
    "Custom/GannFan_Safe.mq4"
    "Custom/GannSquare_Safe.mq4"
    "Custom/GapFillTracker_Safe.mq4"
    "Custom/GreeksSimulator_Safe.mq4"
    "Custom/GridTrading_Safe.mq4"
    "Custom/HighLowPath_Safe.mq4"
    "Custom/ImpliedVolatility_Safe.mq4"
    "Custom/InsideBarCluster_Safe.mq4"
    "Custom/InsideOutsideBar_Safe.mq4"
    "Custom/KeyLevelTest_Safe.mq4"
    "Custom/MTF_RSI_Safe.mq4"
    "Custom/Marubozu_Safe.mq4"
    "Custom/McClellanOscillator_Safe.mq4"
    "Custom/MomentumCandle_Safe.mq4"
    "Custom/NR7_Safe.mq4"
    "Custom/NoDemandNoSupply_Safe.mq4"
    "Custom/OpenInterest_Safe.mq4"
    "Custom/OpeningClosingDrive_Safe.mq4"
    "Custom/PivotCandle_Safe.mq4"
    "Custom/PriceActionScore_Safe.mq4"
    "Custom/RejectionCandle_Safe.mq4"
    "Custom/StoppingVolume_Safe.mq4"
    "Custom/StreakReversal_Safe.mq4"
    "Custom/SwingFailureCandle_Safe.mq4"
    "Custom/SwingMeasuredMove_Safe.mq4"
    "Custom/ThreeBarReversal_Safe.mq4"
    "Custom/TrendExhaustionIndex_Safe.mq4"
    "Custom/Tweezer_Safe.mq4"
    "Custom/UpthrustShakeout_Safe.mq4"
    "Custom/VolumeDeltaDivergence_Safe.mq4"
    "Custom/VolumeSpreadCandle_Safe.mq4"
    "Custom/WRB_HiddenGap_Safe.mq4"
    "Custom/WickReversal_Safe.mq4"
    "Custom/Wyckoff_Safe.mq4"
)

echo "=== MQL4 Pre-Commit Validation ==="

for f in $STAGED_MQ4; do
    if [ ! -f "$f" ]; then continue; fi

    # Check 1: bar[0] signal assignment
    BAR0_VIOLATION=$(grep -n 'signal.*\[0\].*=' "$f" 2>/dev/null | grep -v 'EMPTY_VALUE')
    if [ -n "$BAR0_VIOLATION" ]; then
        echo "[CRITICAL] $f: bar[0] signal assignment detected"
        echo "$BAR0_VIOLATION"
        HAS_CRITICAL=1
    fi

    # Check 2: Buffer count consistency (skip known false positives)
    skip=0
    for known in "${KNOWN_FALSE_POSITIVES[@]}"; do
        if [ "$f" = "$known" ]; then
            skip=1
            break
        fi
    done

    if [ $skip -eq 0 ]; then
        PROP=$(grep -oP 'indicator_buffers\s+\K\d+' "$f" 2>/dev/null || echo "0")
        ACTUAL=$(grep -c "SetIndexBuffer" "$f" 2>/dev/null || echo "0")
        if [ "$PROP" != "$ACTUAL" ] && [ "$PROP" != "0" ]; then
            echo "[CRITICAL] $f: buffer count mismatch (declared=$PROP, actual=$ACTUAL)"
            HAS_CRITICAL=1
        fi
    fi
done

if [ $HAS_CRITICAL -eq 1 ]; then
    echo ""
    echo "COMMIT BLOCKED: Fix CRITICAL violations above before committing."
    exit 1
fi

echo "All checks passed."
exit 0
